# Acquira API — Environment Variables
# Copy this to .env for local development
# In production (Railway), set these in the Variables tab of your Railway project

# PlanningAlerts API key — enables live DA data from planningalerts.org.au
# Get your key at: https://www.planningalerts.org.au/api/keys
# Without this key, the /planning/nearby endpoint returns illustrative mock data
PLANNING_ALERTS_API_KEY=Bmag3xjvKyHuSDpCrd4M

# Other required environment variables (already set in Railway):
# ANTHROPIC_API_KEY=...
# SUPABASE_URL=...
# SUPABASE_SERVICE_KEY=...
# PLANNING_ALERTS_API_KEY configured in Railway
